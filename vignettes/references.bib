@article{amourouxEmergentSeaRechercheSubstances2025,
  title = {{Emergent'Sea. Recherche des substances d'int\'er\^et \'emergent en milieu marin}},
  author = {Amouroux, Isabelle and Gonzalez, Jean-Louis and Grouhel, Anne and Chavanon, Fabienne and Augagneur, Sylvie and Bruneau, Audrey and Budzinski, H{\'e}l{\`e}ne and Dagault, Francoise and Duquesne, Vincent and Gabellec, Raoul and Le Bon, Fabien and Lebrun, Luc and Le Fur, Ines and Le Gall, Patrik and Gianaroli, Camille and Lissardy, Muriel and Maheux, Frank and Munaron, Dominique and Pierre Duplessix, Olivier and Ravel, Christophe and Retho, Michael and Schmidt, Anne and Simon, Benjamin and Sireau, Teddy and Staub, Pierre-Fran{\c c}ois and Tapie, Nathalie and Thevand, Adeline},
  year = 2025,
  month = apr,
  journal = {Ref. Ifremer/RBE/CCEM-ARC-15.12.2024},
  volume = {Contrat R\&D OFB 21-453},
  pages = {61},
  urldate = {2025-07-24},
  abstract = {le projet emergent'sea a \'et\'e conduit en france m\'etropolitaine sur la p\'eriode 2021-2024, par ifremer, epoc et ofb. ce projet a permis l'acquisition de donn\'ees de concentration sur des substances d'int\'er\^et \'emergent (pesticides, pharmaceutiques, biocides, biocides antisalissures, plastifiants, compos\'es m\'etalliques) sur des points de suivi consid\'er\'es comme expos\'es \`a des apports de contaminants issus des bassins versants, sur des matrices int\'egratrices : mollusques (34 points de suivi) et \'echantillonneurs passifs (pocis, dgt) (26 points de suivi). ce projet a ainsi permis une acquisition, sur l'ensemble du littoral fran\c cais, de donn\'ees aussi homog\`enes que possible : p\'eriode d'acquisition, \'echantillonnage, analyses, traitement des donn\'ees. l'objectif final \'etait de pouvoir identifier les substances pertinentes pouvant \^etre propos\'ees in fine en tant que substances candidates psee (polluants sp\'ecifiques de l'etat ecologique) pour les eaux littorales dans le cadre de la dce. la priorisation des substances est r\'ealis\'ee en consid\'erant l'occurrence des contaminations et une approche risque, elle s'appuie sur la m\'ethodologie de priorisation du cep (comit\'e expert priorisation), et utilise des pnec (concentration pr\'edite sans effet) d\'etermin\'ees par ineris, ou issues du r\'eseau norman. la priorisation concerne uniquement les substances organiques. parmi les 102 substances organiques recherch\'ees, 77\% des substances << quantifiables >> sont quantifi\'ees en eau marine (51 / 66 substances) et 65 \% dans les mollusques (34/52 substances). ce projet permet ainsi de proposer une liste de substances prioris\'ees sur eau marine et une liste de substances prioris\'ees sur mollusques, substances pouvant \^etre consid\'er\'ees comme pertinentes pour un suivi en eau littorale. cette d\'emarche permet de d\'emontrer \`a l'\'echelle nationale la compl\'ementarit\'e des suivis en eau marine via \'echantillonneurs passifs et dans les mollusques, elle met \'egalement en \'evidence un manque de pnec eau marine, pnec mollusques[...]},
  langid = {french},
  file = {C\:\\Users\\fmounier\\Zotero\\storage\\M3EYX8HW\\Amouroux et al. - 2025 - Emergent’Sea. Recherche des substances d’intérêt émergent en milieu marin.pdf;C\:\\Users\\fmounier\\Zotero\\storage\\DXHYS9TE\\106772.html}
}
