@article{elliottEstuarineQualityParadox2007,
  title = {The {{Estuarine Quality Paradox}}, {{Environmental Homeostasis}} and the Difficulty of Detecting Anthropogenic Stress in Naturally Stressed Areas},
  author = {Elliott, Michael and Quintino, Victor},
  year = 2007,
  journal = {Marine Pollution Bulletin},
  volume = {54},
  number = {6},
  pages = {640--645},
  issn = {0025-326X (Print) 0025-326X (Linking)},
  doi = {10.1016/j.marpolbul.2007.02.003},
  abstract = {Estuaries have long been regarded as environmentally naturally stressed areas because of the high degree of variability in their physico-chemical characteristics, for example oxygen, temperature and salinity in the water column and bed sediment dynamics. However, their biota is well-adapted to cope with that stress and so the areas may be regarded as resilient because of that inherent variability; their ability to absorb stress without adverse effects is regarded here as Environmental Homeostasis. Hence these areas may only be regarded as stressful for marine or freshwater-adapted organisms and that for estuarine organisms this environmental stress is regarded as a subsidy whereby they successfully capitalise on the stressful conditions. In addition, using examples of the estuarine fauna and flora, this article indicates that the characteristics of natural stress in estuaries are similar to those for anthropogenic stress. An over-reliance on ecosystem structural features, such as diversity, in quality indicators therefore makes the detection of the anthropogenic stress more difficult. This difficulty is termed the Estuarine Quality Paradox. Because of these difficulties, the article argues that functional characteristics either as well as or rather than structural ones should be used in detecting environmental perturbations in estuaries. \copyright{} 2007 Elsevier Ltd. All rights reserved.},
  keywords = {Benthos,Biodiversity-ecosystem functioning,Environmental Homeostasis,Estuaries,Estuarine Quality Paradox,Resilience,Stress},
  file = {C:\Users\fmounier\Zotero\storage\JFU84BWV\Elliott et Quintino - 2007 - The Estuarine Quality Paradox, Environmental Homeostasis and the difficulty of detecting anthropogen.pdf}
}

@article{arevaloFishLarvaeDynamics2023,
  title = {Fish Larvae Dynamics in Temperate Estuaries: {{A}} Review on Processes, Patterns and Factors That Determine Recruitment},
  shorttitle = {Fish Larvae Dynamics in Temperate Estuaries},
  author = {Arevalo, Elorri and Cabral, Henrique N. and Villeneuve, Bertrand and Poss{\'e}m{\'e}, Carl and Lepage, Mario},
  year = 2023,
  journal = {Fish and Fisheries},
  volume = {24},
  number = {3},
  pages = {466--487},
  issn = {1467-2979},
  doi = {10.1111/faf.12740},
  urldate = {2026-06-09},
  abstract = {Early life stages of fish (eggs and larvae) are particularly vulnerable with mortality rates of up to 99\% recorded for a large number of species. High mortality rates result from the limited swimming ability of larvae preventing them from escaping sub-optimal environmental conditions, predators or low prey density areas. In this context, estuaries are key nursery areas for larval and juvenile fish. Estuarine habitats offer environmental conditions favourable to the survival and growth of early stages, through abundant good-quality prey and protection from predators. A vast literature on larvae occurring in temperate estuaries exists, but an overall perspective is lacking. The occurrence of fish larvae in temperate estuaries depends on several factors. First, the choice of spawning time and location is primordial, as they have evolved to optimise the entry and the retention of larvae in the estuary as well as the conditions experienced by young stages. Secondly, larval growth and survival depend on key environmental factors (e.g. salinity, water temperature, freshwater inputs, turbidity and dissolved oxygen concentration). Knowledge of the larval dynamics in temperate estuaries is scarce for some topics and biased towards some species or geographical areas. The main goal of the present literature review is to synthesise existing knowledge regarding spawning timing and location and larval ecology for fish species occurring in coasts and estuaries, identifying the main patterns, consensus or conflicting hypotheses and highlighting major gaps. Research needs and future perspectives were outlined.},
  copyright = {\copyright{} 2023 The Authors. Fish and Fisheries published by John Wiley \& Sons Ltd.},
  langid = {english},
  keywords = {early life stages,ichthyoplankton,nursery habitats,retention,spawning strategies,survival},
  file = {C\:\\Users\\fmounier\\Zotero\\storage\\3PU9MBL5\\Arevalo et al. - 2023 - Fish larvae dynamics in temperate estuaries A review on processes, patterns and factors that determ.pdf;C\:\\Users\\fmounier\\Zotero\\storage\\8M3ZGY5I\\faf.html}
}

@article{baptistaEffectsFreshwaterFlow2010,
  title = {Effects of Freshwater Flow on the Fish Assemblage of the {{Mondego}} Estuary ({{Portugal}}): Comparison between Drought and Non-Drought Years},
  shorttitle = {Effects of Freshwater Flow on the Fish Assemblage of the {{Mondego}} Estuary ({{Portugal}})},
  author = {Baptista, Joana and Martinho, Filipe and Dolbeth, Marina and Viegas, Ivan and Cabral, Henrique and Pardal, Miguel},
  year = 2010,
  month = apr,
  journal = {Marine \& Freshwater Research},
  volume = {61},
  number = {4},
  pages = {490--501},
  issn = {1323-1650},
  doi = {10.1071/MF09174},
  urldate = {2026-06-09},
  abstract = {Warming of the planet is indisputable and will lead to more frequent extreme events, such as droughts. From June 2003 to March 2008, the effects of variations in river flow, associated with drought conditions, were studied in the fish assemblage of the Mondego estuary, Portugal. Over this time, two distinct hydrological periods were identified: non-drought years and drought years, with consistent changes in the fish assemblages. In the drought years, salinity increased inside the estuary, displacing the estuarine brackish habitats to more upstream areas. During this period, new marine adventitious species were found mainly in the most downstream areas, while the freshwater species disappeared from the Mondego estuary catchment area. For the marine estuarine-dependent species that use estuaries as nursery areas, a decrease in abundance was observed during the drought years, owing to the decrease in freshwater flow and reduced river plume to the coastal area. In non-drought years, there were higher densities of most species and the more important species of the fish community. Our work shows that extreme events such as droughts, related to climatic changes, influenced the structure and composition of the Mondego estuary fish assemblages, and should be further considered when undertaking management plans for transitional waters.},
  file = {C:\Users\fmounier\Zotero\storage\FZW656NX\Baptista et al. - 2010 - Effects of freshwater flow on the fish assemblage of the Mondego estuary (Portugal) comparison betw.pdf}
}

@article{safePolychlorinatedBiphenylsPCBs1990,
  title = {Polychlorinated {{Biphenyls}} ({{PCBs}}), {{Dibenzo-p-Dioxins}} ({{PCDDs}}), {{Dibenzofurans}} ({{PCDFs}}), and {{Related Compounds}}: {{Environmental}} and {{Mechanistic Considerations Which Support}} the {{Development}} of {{Toxic Equivalency Factors}} ({{TEFs}})},
  shorttitle = {Polychlorinated {{Biphenyls}} ({{PCBs}}), {{Dibenzo-p-Dioxins}} ({{PCDDs}}), {{Dibenzofurans}} ({{PCDFs}}), and {{Related Compounds}}},
  author = {Safe, Stephen},
  year = 1990,
  month = jan,
  journal = {Critical Reviews in Toxicology},
  volume = {21},
  number = {1},
  pages = {51--88},
  publisher = {Taylor \& Francis},
  issn = {1040-8444},
  doi = {10.3109/10408449009089873},
  urldate = {2025-07-31},
  abstract = {Halogenated aromatic compounds, typified by the polychlorinated dibenzo-p-dioxins (PCDDs), dibenzofurans (PCDFs), biphenyls (PCBs), and diphenylethers (PCDEs), are industrial compounds or byproducts which have been widely identified in the environment and in chemical-waste dumpsites. Halogenated aromatics are invariably present in diverse analytes as highly complex mixtures of isomers and congeners and this complicates the hazard and risk assessment of these compounds. Several studies have confirmed the common receptor-mediated mechanism of action of toxic halogenated aromatics and this has resulted in the development of structure-activity relationships for this class of chemicals. The most toxic halogenated aromatic is 2,3,7,8-tetrachlorodibenzo-p-dioxin (TCDD) and based onin vivo andin vitro studies the relative toxicities of individual halogenated aromatics have been determined relative to TCDD (i.e., toxic equivalents). The derived toxic equivalents can be used for hazard and risk assessment of halogenated aromatic mixtures; moreover, for more complex mixtures containing congeners for which no standards are available (e.g., bromo/chloro mixtures), severalin vitro orin vivo assays can be utilized for hazard or risk assessment.},
  pmid = {2124811},
  keywords = {2378-TCDD,halogenated aromatics,toxic equivalency factors},
  file = {C:\Users\fmounier\Zotero\storage\WPVJKR3E\Safe - 1990 - Polychlorinated Biphenyls (PCBs), Dibenzo-p-Dioxins (PCDDs), Dibenzofurans (PCDFs), and Related Comp.pdf}
}
